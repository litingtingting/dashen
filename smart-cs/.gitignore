# 智能客服系统 - Git 忽略文件

# 环境变量（包含 API Key 等敏感信息）
.env
.env.*
!.env.example
!.env.test

# 配置文件（包含敏感配置）
configs/config.yml
configs/*.local.yml
!configs/config.example.yml
!configs/config.test.yml

# 数据库文件
data/*.db
data/*.db-journal
*.db

# 日志文件
logs/
*.log

# 编译产物
smart-cs
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Go 相关
go.work
go.work.sum
vendor/

# 测试覆盖率
coverage.txt
coverage.out

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store

# 临时文件
tmp/
temp/
*.tmp
