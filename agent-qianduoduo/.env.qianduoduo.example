# qianduoduo-docker/env.example
# ❗请复制为 .env.qianduoduo 并填写真实密钥（不提交 Git）

# iTick API
ITICK_TOKEN=your_iTick_token_here

# Tushare API
TUSHARE_TOKEN=your_tushare_token_here

# Brave API（用于浏览器搜索）
BRAVE_API_KEY=your_brave_api_key_here

# 飞书 Bot 配置（如需要自建）
FEISHU_APP_ID=your_feishu_app_id
FEISHU_APP_SECRET=your_feishu_app_secret

# OpenClaw Gateway 地址（容器编排后自动注入）
# http://localhost:12131
OPENCLAW_GATEWAY=http://localhost:12131

# 容器 ID（自动注入）
CONTAINER_ID=qianduoduo-quant

#百炼
BAILIAN_BASEURL=https://coding.dashscope.aliyuncs.com/v1
BAILIAN_APIKEY=sk-sp-xxxxxx
